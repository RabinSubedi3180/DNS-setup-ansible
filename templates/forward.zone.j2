$TTL 86400
@	IN	SOA	ns1.{{ domain_name }}. root.{{ domain_name }}. (

		{{ zone_serial }} ; Serial
		3600	   ; Refresh
		1800	   ; Retry
		604800	   ; Expire
		86400 )	   ; Minimum TTL

; Name Server Information
@	IN	NS	ns1.{{ domain_name }}.

; IP Address mapping for name server
ns1	IN	A	{{ dns_ip }}

; A records for hosts


{% for host in groups['company_nodes'] %}
{{ host }} 	IN	A	{{ hostvars[host]['ansible_host'] }}	
{% endfor %}
